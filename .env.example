NEXT_PUBLIC_SUPABASE_URL=https://ycadmmngkdhvpcsrcuaq.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Feature flag — gates the live surface. Default OFF (§7.3, §11 P5).
